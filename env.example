# nano-vm Banner Demo — environment variables
# ─────────────────────────────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore — NEVER commit .env to git.

# ── Stripe ────────────────────────────────────────────────────────────────────
# For stripe-mock (local dev / demo): any sk_test_ key with exactly 24 chars after prefix.
# Generate one: python3 -c "import secrets; print('sk_test_' + secrets.token_hex(12))"
STRIPE_SK=

# Publishable key — safe for frontend, but still keep out of git.
# For stripe-mock: use matching pk_test_ key.
STRIPE_PK=

# ── stripe-mock (optional) ────────────────────────────────────────────────────
# Set this to use stripe-mock instead of real Stripe API.
# Leave empty to use real Stripe (STRIPE_SK must be a real test/live key).
STRIPE_MOCK_HOST=http://127.0.0.1:12111

# ── App auth ──────────────────────────────────────────────────────────────────
# Bearer token for /api/run, /api/sabotage, /api/gdpr-erase.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty for open demo mode (warning logged, not for public internet).
NANO_VM_API_KEY=
